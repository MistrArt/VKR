rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Helper Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    // Check for admin role (stored in /admins/{uid} or check users collection)
    // For simplicity and since users can register as admin in this demo, 
    // we'll check the users collection for the role field.
    function isAdmin() { 
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 3. User Profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid is string && data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 256 &&
               data.role in ['tourist', 'partner', 'admin'] &&
               (!('name' in data) || (data.name is string && data.name.size() <= 100)) &&
               (!('favorites' in data) || (data.favorites is list && data.favorites.size() <= 1000));
      }

      allow get: if isSignedIn();
      allow list: if isAdmin();
      
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && (
        incoming().role == existing().role || isAdmin() || (existing().role == 'tourist' && incoming().role in ['tourist', 'partner', 'admin'])
      );
    }

    // 4. Partner Requests
    match /partnerRequests/{requestId} {
      allow create: if true; // Allow anyone to apply
      allow read, update, delete: if isAdmin();
    }

    // 5. Routes
    match /routes/{routeId} {
      function isValidRoute(data) {
        return data.userId == request.auth.uid &&
               data.title is string && data.title.size() <= 200 &&
               data.waypoints is list && data.waypoints.size() <= 50;
      }

      allow get: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && isValidRoute(incoming()) && isValidId(routeId);
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidRoute(incoming()) && (
        incoming().userId == existing().userId &&
        incoming().diff(existing()).affectedKeys().hasOnly(['title', 'startPoint', 'endPoint', 'waypoints', 'updatedAt'])
      );
      allow delete: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
    }
  }
}
