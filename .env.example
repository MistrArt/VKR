# URL бэкенда (опционально). По умолчанию Vite проксирует /api на http://localhost:8080
# VITE_API_URL=http://localhost:8080

# Яндекс.Карты — скопируйте в .env.local (https://developer.tech.yandex.ru)
#   Copy-Item .env.example .env.local
# Нужны: JavaScript API, HTTP Геокодер, Геосаджест (маршруты — бесплатно через OSRM, см. ниже)

# JavaScript API 2.1 (карта на сайте)
VITE_YANDEX_MAPS_API_KEY=88c27798-5172-4759-9e55-d2d027ffa56f

# Геосаджест
VITE_YANDEX_SUGGEST_API_KEY=ccdbff1c-52f8-46af-b622-14c3c0012fc6

# HTTP Геокодер (адреса в конструкторе)
VITE_YANDEX_GEOCODER_API_KEY=c988c657-36b0-4cd1-96db-88267a62d9af

# Платный Router API Яндекса НЕ нужен.
# Маршруты и время в пути: OSRM (OpenStreetMap) + запасная оценка по расстоянию.

# При CORS на гео-API Яндекса: true и прокси /api/geo/* на бэкенде
# VITE_YANDEX_GEO_PROXY=false
